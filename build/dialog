SITE=https://mirrors.omnios.org/dialog
VER=1.3-20240619
FILE=dialog-$VER.tgz
URL=$SITE/$FILE
PROG=dialog

dir=`/usr/gnu/bin/mktemp -d`

(
	cd $dir
	curl -fLO $URL
	gtar -zxf $FILE
	cd $PROG-$VER
	./configure CFLAGS="-m32 -std=gnu17"
	gmake
)

out=$dir/$PROG-$VER/$PROG

if [ ! -f "$out" ]; then
	print -u2 "Failed to build dialog"
	exit 1
fi

cp $out ./bin/$PROG
strip bin/$PROG
ldd bin/$PROG | egrep -s ncurses && {
	print -u2 "Dialogue binary should not be using ncurses"
	print "DIR: $dir"
	exit 1
}

rm -rf $dir

